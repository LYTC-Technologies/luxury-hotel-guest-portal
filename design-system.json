{
  "name": "Luxury Hotel Guest Portal Design System",
  "version": "1.0.0",
  "colors": {
    "primary": {
      "gold": "#dfba73",
      "goldLight": "#cbba53",
      "goldDark": "#b8a060"
    },
    "background": {
      "primary": "#080808",
      "secondary": "#000000",
      "glass": "rgba(255, 255, 255, 0.05)",
      "glassLight": "rgba(255, 255, 255, 0.08)"
    },
    "text": {
      "primary": "#ffffff",
      "secondary": "#e0e0e0",
      "muted": "#9ca3af",
      "disabled": "#6b7280"
    },
    "border": {
      "default": "rgba(255, 255, 255, 0.1)",
      "gold": "rgba(223, 186, 115, 0.3)",
      "goldHover": "rgba(223, 186, 115, 0.5)",
      "error": "rgba(239, 68, 68, 0.3)",
      "success": "rgba(34, 197, 94, 0.3)"
    },
    "status": {
      "pending": "#eab308",
      "preparing": "#3b82f6",
      "onTheWay": "#6366f1",
      "completed": "#22c55e",
      "cancelled": "#ef4444"
    },
    "gradients": {
      "gold": "from-[#cbba53] via-[#dfba73] to-[#cbba53]",
      "goldSubtle": "from-[#dfba73]/10 to-[#dfba73]/5",
      "amber": "from-amber-500/20 to-[#dfba73]/10",
      "purple": "from-purple-500/20 to-pink-500/10",
      "emerald": "from-emerald-500/20 to-teal-500/10",
      "blue": "from-blue-500/10 to-[#dfba73]/10",
      "rose": "from-rose-500/10 to-amber-500/10",
      "cyan": "from-cyan-500/10 to-blue-500/10"
    }
  },
  "typography": {
    "fonts": {
      "serif": "font-serif",
      "sans": "font-sans",
      "mono": "font-mono"
    },
    "sizes": {
      "xs": "text-[10px]",
      "sm": "text-xs",
      "base": "text-sm",
      "lg": "text-base",
      "xl": "text-lg",
      "2xl": "text-xl",
      "3xl": "text-2xl",
      "4xl": "text-3xl"
    },
    "weights": {
      "normal": "font-normal",
      "medium": "font-medium",
      "semibold": "font-semibold",
      "bold": "font-bold"
    }
  },
  "spacing": {
    "xs": "0.5rem",
    "sm": "0.75rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem",
    "2xl": "3rem"
  },
  "borderRadius": {
    "sm": "rounded-lg",
    "md": "rounded-xl",
    "lg": "rounded-2xl",
    "full": "rounded-full"
  },
  "shadows": {
    "glass": "shadow-[0_10px_30px_rgba(0,0,0,0.8)]",
    "goldGlow": "gold-border-glow",
    "textGlow": "gold-text-glow"
  },
  "animations": {
    "duration": {
      "fast": "0.2s",
      "normal": "0.5s",
      "slow": "0.8s"
    },
    "easing": {
      "spring": "spring",
      "linear": "linear",
      "easeInOut": "easeInOut"
    }
  },
  "components": {
    "glassPanel": {
      "className": "glass-panel rounded-2xl border border-white/10 bg-black/50 backdrop-blur-xl"
    },
    "glassPanelLight": {
      "className": "glass-panel-light border-white/10 backdrop-blur-xl"
    },
    "glassPanelGold": {
      "className": "glass-panel-gold rounded-2xl border border-[#dfba73]/30 bg-[#dfba73]/5"
    },
    "button": {
      "primary": "bg-gradient-to-r from-[#cbba53] via-[#dfba73] to-[#cbba53] text-black font-bold",
      "secondary": "bg-white/5 text-white border border-white/10 hover:border-[#dfba73]/30",
      "danger": "bg-red-500/10 text-red-400 border border-red-500/20"
    },
    "input": {
      "default": "bg-black/50 border border-white/10 text-white focus:border-[#dfba73] outline-none"
    }
  },
  "icons": {
    "primaryColor": "#dfba73",
    "mutedColor": "#6b7280",
    "sizes": {
      "xs": "w-3 h-3",
      "sm": "w-4 h-4",
      "md": "w-5 h-5",
      "lg": "w-6 h-6",
      "xl": "w-8 h-8",
      "2xl": "w-12 h-12",
      "3xl": "w-16 h-16"
    }
  },
  "effects": {
    "goldTextGlow": {
      "description": "Subtle golden glow effect on text",
      "className": "gold-text-glow"
    },
    "goldBorderGlow": {
      "description": "Subtle golden glow effect on borders",
      "className": "gold-border-glow"
    },
    "luxuryFade": {
      "description": "Luxury fade animation",
      "className": "animate-luxury-fade"
    }
  },
  "touchTargets": {
    "minimum": "44px",
    "className": "touch-target"
  }
}
